# ──────────────────────────────────────────────────
# GostForge — Environment Variables (development)
# Скопировать в .env и заполнить значения.
# ──────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────
POSTGRES_DB=gostforge
POSTGRES_USER=gostforge
POSTGRES_PASSWORD=gostforge_secret
POSTGRES_PORT=5432

# ── Redis ─────────────────────────────────────────
REDIS_PASSWORD=gostforge_redis
REDIS_PORT=6379

# ── MinIO ─────────────────────────────────────────
MINIO_ACCESS_KEY=gostforge
MINIO_SECRET_KEY=gostforge_minio
MINIO_BUCKET=gostforge
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── md2gost-service ───────────────────────────────
MD2GOST_PORT=8081

# ── Gotenberg ─────────────────────────────────────
GOTENBERG_PORT=3000

# ── Backend ───────────────────────────────────────
BACKEND_PORT=8080
CORS_ORIGINS=http://localhost:3001,http://localhost:5173

# ── Frontend (TypeScript/Vite MVP) ───────────────
FRONTEND_PORT=3001

# ── JWT (RS256) ───────────────────────────────────
# Сгенерировать:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
# Затем вставить содержимое файлов (одной строкой через \n):
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# ── Telegram Bot ──────────────────────────────────
GOSTFORGE_BOT_TOKEN=
GOSTFORGE_MINI_APP_URL=http://localhost:3001
GOSTFORGE_MAX_FILE_SIZE_MB=20
